IMATE HOME GOLF SIMULATOR.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":null},\"content\":[{\"text\":\"Transform your home into the ultimate golf experience. Practice, play, and improve with the most accurate and realistic simulator designed for serious golfers.\",\"type\":\"text\"}]}]},\"layout_mobile\":\"img_top\",\"layout_desktop\":\"img_left\",\"video_thumbnail\":{\"id\":null,\"alt\":null,\"name\":\"\",\"focus\":null,\"title\":null,\"source\":null,\"filename\":\"\",\"copyright\":null,\"fieldtype\":\"asset\",\"meta_data\":{}},\"new_web_component\":false,\"image_aspect_ratio\":\"1/1\"},{\"cta\":[{\"url\":{\"id\":\"5a761309-a52b-40e6-8fc8-7b1efa555261\",\"url\":\"\",\"linktype\":\"story\",\"fieldtype\":\"multilink\",\"cached_url\":\"lp/contact-form-trackman-360\"},\"_uid\":\"d3fcd45f-e742-43b7-acad-b91b091771cf\",\"label\":\"Download the brochure\",\"component\":\"link\",\"variation\":\"primary\"}],\"_uid\":\"bb9d233a-7dde-4813-82a7-4ab5b0c37a55\",\"image\":{\"id\":null,\"alt\":null,\"name\":\"\",\"focus\":null,\"title\":null,\"source\":null,\"filename\":\"\",\"copyright\":null,\"fieldtype\":\"asset\",\"meta_data\":{}},\"video\":{\"id\":null,\"alt\":null,\"name\":\"\",\"focus\":null,\"title\":null,\"source\":null,\"filename\":\"\",\"copyright\":null,\"fieldtype\":\"asset\",\"meta_data\":{}},\"content\":[],\"padding\":[{\"top\":\"m\",\"_uid\":\"9dba724a-d41d-4b21-8e86-fe700ee5a374\",\"bottom\":\"l\",\"component\":\"padding\"}],\"component\":\"media_with_text\",\"video_url\":\"https://vimeo.com/1132111706/829094994b?share=copy\u0026fl=sv\u0026fe=ci\",\"dark_theme\":true,\"image_fill\":\"cover\",\"rich_content\":{\"type\":\"doc\",\"content\":[{\"type\":\"heading\",\"attrs\":{\"level\":2,\"textAlign\":null},\"content\":[{\"text\":\"Powering clubs.\u2028\",\"type\":\"text\",\"marks\":[{\"type\":\"underline\"}]},{\"text\":\"empowering players.\",\"type\":\"text\"}]},{\"type\":\"paragraph\",\"attrs\":{\"textAlign\":null},\"content\":[{\"text\":\