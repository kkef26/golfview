-span-5 xl:col-start-18 xl:col-span-9 row-start-1 mb-6 md:mb-0"><div class="relative aspect-video flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-16 z-1 cursor-pointer opacity-70 transition duration-300 hover:opacity-50 pointer-events-none"><path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm14.024-.983a1.125 1.125 0 0 1 0 1.966l-5.603 3.113A1.125 1.125 0 0 1 9 15.113V8.887c0-.857.921-1.4 1.671-.983l5.603 3.113Z" clip-rule="evenodd"></path></svg><img alt="Man sitting at a golf driving range, wearing a black shirt with a name tag. Text reads &quot;Watch the Video&quot; and &quot;360&quot; with related keywords." type="button" aria-haspopup="dialog" aria-expanded="false" aria-controls="radix-:Ra9ljq6jsq:" data-state="closed" loading="lazy" decoding="async" data-nimg="fill" class="object-cover cursor-pointer" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent" sizes="100vw" srcSet="/_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=640&amp;q=100 640w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=750&amp;q=100 750w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=828&amp;q=100 828w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=1080&amp;q=100 1080w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=1200&amp;q=100 1200w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=1920&amp;q=100 1920w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=2048&amp;q=100 2048w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=3840&amp;q=100 3840w" src="/_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F1240x800%2Fab1f6d5419%2Ftm_360_video1_thumbnail.webp&amp;w=3840&amp;q=100"/></div></div><div class="flex flex-col justify-center text-center md:text-left [&amp;_h1]:drop-shadow-2xl [&amp;_h2]:drop-shadow-2xl [&amp;_p]:drop-shadow-2xl col-start-1 col-span-4 md:mr-5 lg:mr-0 lg:col-start-3 lg:col-span-6 xl:col-start-7 xl:col-span-9 row-start-2 md:row-start-1"><h2 class="mb-6 [&amp;&gt;u]:no-underline [&amp;&gt;u]:text-tm-c-primary"><u>Powering clubs. </u>empowering players.</h2><p class="font-medium text-base lg:text-lg mb-5 last-of-type:mb-0 [&amp;&gt;u]:no-underline [&amp;&gt;u]:text-tm-c-primary"><span>Whether you’re running a club or swinging a club, Trackman 360 delivers all the tools you need to work smarter and play better - all in one place.</span><br/><br/><span>From coaching and range to indoor simulators, the app, and business tools, all Trackman products work in sync to keep your business optimized and members engaged year-round.</span></p><div class="flex gap-5 mt-6 flex-col md:flex-row items-center"><a target="_self" class="inline-flex items-center justify-center whitespace-nowrap text-base xl:text-lg font-medium tracking-tight ring-offset-white transition-colors focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:ring-offset-neutral-950 text-tm-c-light border-2 rounded-md border-tm-c-primary w-full max-w-[320px] text-center bg-tm-c-primary hover:bg-[#ab490e] hover:border-[#ab490e] h-10 px-4 py-2" href="/lp/contact-form-trackman-360">Download the brochure</a></div></div></div></section><div class="relative bg-tm-c-dark text-tm-c-light font-[10px]"><div class="z-1 block lg:absolute lg:transform lg:-translate-y-1/2 lg:top-1/2 lg:pointer-events-none"><div class="grid-container mb-[60px] bg-transparent w-full"><div class="mx-5 text-center lg:mx-auto col-span-4 md:col-span-8 lg:col-start-2 lg:col-span-6 lg:text-left 2xl:col-start-5 2xl:col-span-8"><h2 class="m-0 mb-6 drop-shadow-2xl">VIRTUAL GOLF 3</h2><p class="font-medium text-base lg:text-lg drop-shadow-2xl">Step into a Trackman simulator and see how VG3 — the latest evolution of our industry-leading graphics engine — makes indoor golf even more realistic and more fun.</p></div></div></div><div class="h-[335px] sm:h-[400px] lg:h-[80vh]" style="position:relative;display:flex;overflow:hidden;touch-action:none;user-select:none;-khtml-user-select:none;-ms-user-select:none;-moz-user-select:none;-webkit-user-select:none" data-rcs="root"><img alt="Aerial view of a rocky coastal landscape with a narrow path leading to a grassy area, surrounded by the ocean under a cloudy sky." loading="lazy" decoding="async" data-nimg="fill" class="lg:hidden object-cover" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent" sizes="100vw" srcSet="/_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F786x670%2F55ef4d7fab%2Fvirtual_golf_3_photo_simulator_trackman_mobile_webp.webp&amp;w=640&amp;q=100 640w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F786x670%2F55ef4d7fab%2Fvirtual_golf_3_photo_simulator_trackman_mobile_webp.webp&amp;w=750&amp;q=100 750w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F786x670%2F55ef4d7fab%2Fvirtual_golf_3_photo_simulator_trackman_mobile_webp.webp&amp;w=828&amp;q=100 828w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F786x670%2F55ef4d7fab%2Fvirtual_golf_3_photo_simulator_trackman_mobile_webp.webp&amp;w=1080&amp;q=100 1080w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F117513%2F786x670%2F55ef4d7fab%2Fvirtual_golf_3_photo_simulator_trackman_mobile_webp.webp&amp;w=1200&amp;q=100 1200w, /_next/image?url=https%3A%2F%2Fa.storyblok.com%2Ff%2F1